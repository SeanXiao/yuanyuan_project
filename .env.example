MINIMAX_API_KEY=your_minimax_key_here
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_MODEL=MiniMax-M2.7
MINIMAX_TTS_MODEL=speech-2.8-hd
MINIMAX_TTS_VOICE="Chinese (Mandarin)_Warm_Girl"
PORT=8787

# 阿里云百炼 / DashScope，可用时会优先用于“桂韵创想家”的文本和图片生成
DASHSCOPE_API_KEY=your_dashscope_key_here
BAILIAN_TEXT_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_TEXT_MODEL=qwen3.7-max
BAILIAN_FAST_TEXT_MODEL=qwen-turbo
BAILIAN_STORY_TEXT_MODEL=qwen-turbo
BAILIAN_STORY_TEXT_TIMEOUT_MS=28000
BAILIAN_STORY_TEXT_MAX_TOKENS=2600
BAILIAN_INSPIRATION_TEXT_MODEL=qwen-turbo
BAILIAN_IMAGE_MODEL=wan2.7-image-pro
BAILIAN_IMAGE_SIZE=2K
